{
  "plugins": [
    "@release-it/conventional-changelog",
    "@release-it-plugins/workspaces"
  ],
  "npm": {
    "publish": false
  },
  "git": {
    "commitMessage": "chore(release): bump package versions",
    "commit": true,
    "tag": false,
    "push": true
  },
  "github": {
    "release": false
  },
  "workspaces": {
    "workspaces": ["packages/*"],
    "publish": true,
    "skipChecks": true,
    "additionalManifests": {
      "versionUpdates": []
    }
  }
}
