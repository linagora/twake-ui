{
  "plugins": {
    "@release-it/conventional-changelog": true,
    "@release-it-plugins/workspaces": {
      "publish": true,
      "skipChecks": true,
      "additionalManifests": {
        "versionUpdates": []
      }
    }
  },
  "npm": false,
  "git": {
    "commitMessage": "chore(release): bump package versions",
    "commit": true,
    "tag": false,
    "push": true
  },
  "github": {
    "release": false
  }
}
