{
  "name": "@linagora/twake-mui",
  "type": "module",
  "version": "1.6.1",
  "description": "MUI v7 theme system for Twake applications",
  "author": "Twake",
  "license": "MIT",
  "engines": {
    "node": "24.x"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/linagora/twake-ui.git",
    "directory": "packages/twake-mui"
  },
  "keywords": [
    "twake",
    "mui",
    "theme",
    "material-ui",
    "react"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "build:doc": "storybook build --output-dir storybook-static",
    "start": "tsc --watch",
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "clean": "rm -rf dist",
    "doc": "storybook dev -p 6006",
    "screenshots": "vitest run"
  },
  "peerDependencies": {
    "@emotion/react": "^11.5.0",
    "@emotion/styled": "^11.3.0",
    "@mui/material": "^7.1.2",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@argos-ci/cli": "4.2.0",
    "@argos-ci/storybook": "5.3.2",
    "@emotion/react": "^11.5.0",
    "@emotion/styled": "^11.3.0",
    "@mui/icons-material": "7.3.10",
    "@mui/material": "^7.1.2",
    "@storybook/addon-docs": "10.3.5",
    "@storybook/addon-vitest": "10.3.5",
    "@storybook/builder-vite": "10.3.5",
    "@storybook/react": "10.3.5",
    "@storybook/react-vite": "10.3.5",
    "@types/lodash": "4.17.24",
    "@vitest/browser-playwright": "4.1.5",
    "cozy-tsconfig": "^2.0.0",
    "eslint": "10.2.1",
    "eslint-config-cozy-app": "7.0.0",
    "eslint-plugin-storybook": "10.3.5",
    "lodash": "4.18.1",
    "playwright": "1.59.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "storybook": "10.3.5",
    "vite": "8.0.9",
    "vitest": "4.1.5"
  }
}
